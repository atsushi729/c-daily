#!/usr/bin/env python3
# bin/cdl — thin entry point for git clone / Homebrew installs.
# When installed via pip/pipx/uvx, the entry_point in pyproject.toml is used instead.
import sys
from pathlib import Path

# Support both installed package (pip/pipx/uvx) and git clone
_root = Path(__file__).resolve().parent.parent
if str(_root) not in sys.path:
    sys.path.insert(0, str(_root))

from cdl.__main__ import main  # noqa: E402

main()
