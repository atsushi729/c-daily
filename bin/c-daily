#!/bin/bash
# c-daily — Claude Code daily log CLI
set -euo pipefail

C_DAILY_VERSION="0.1.0"
_SCRIPT="$(readlink "$0" 2>/dev/null || echo "$0")"
[[ "$_SCRIPT" != /* ]] && _SCRIPT="$(cd "$(dirname "$0")" && pwd)/$_SCRIPT"
C_DAILY_LIB="$(cd "$(dirname "$_SCRIPT")/../lib" && pwd)"
C_DAILY_LOG_DIR="${C_DAILY_LOG_DIR:-${HOME}/.daily-logs}"

_usage() {
  cat <<EOF
c-daily v${C_DAILY_VERSION} — Claude Code daily log auto-generator

Usage:
  c-daily install            Set up Claude Code hooks and launchd
  c-daily today              Generate and open today's log
  c-daily show [DATE]        Generate and open log for a specific date (e.g. 2026-03-22)
  c-daily status             Check hook and launchd status
  c-daily raw [DATE]         Display raw log (JSONL)
  c-daily uninstall          Remove all settings
  c-daily version            Show version
  c-daily help               Show this help

Environment variables:
  C_DAILY_LOG_DIR   Log storage directory (default: ~/.daily-logs)
EOF
}

CMD="${1:-help}"
shift || true

case "$CMD" in
  install)   bash "$C_DAILY_LIB/cmd/install.sh" "$@" ;;
  today)
    python3 "$C_DAILY_LIB/aggregate.py"
    OUTFILE="${C_DAILY_LOG_DIR}/$(date +%Y-%m-%d).md"
    if [ -f "$OUTFILE" ]; then
      open "$OUTFILE" 2>/dev/null || xdg-open "$OUTFILE" 2>/dev/null || echo "📄 $OUTFILE"
    fi
    ;;
  show)
    DATE="${1:-$(date +%Y-%m-%d)}"
    python3 "$C_DAILY_LIB/aggregate.py" "$DATE"
    OUTFILE="${C_DAILY_LOG_DIR}/${DATE}.md"
    if [ -f "$OUTFILE" ]; then
      open "$OUTFILE" 2>/dev/null || xdg-open "$OUTFILE" 2>/dev/null || echo "📄 $OUTFILE"
    fi
    ;;
  status)    bash "$C_DAILY_LIB/cmd/status.sh" ;;
  raw)
    DATE="${1:-$(date +%Y-%m-%d)}"
    RAW="${C_DAILY_LOG_DIR}/raw/${DATE}.jsonl"
    if [ -f "$RAW" ]; then
      cat "$RAW"
    else
      echo "⚠️  Log file not found: $RAW"
      exit 1
    fi
    ;;
  uninstall) bash "$C_DAILY_LIB/cmd/uninstall.sh" ;;
  version)   echo "c-daily v${C_DAILY_VERSION}" ;;
  help|--help|-h) _usage ;;
  *)
    echo "❌ Unknown command: $CMD"
    echo ""
    _usage
    exit 1
    ;;
esac
